# Copy this file to .env and fill in real values before running `docker compose up`.
# docker compose automatically loads .env from the project root.

# Gmail account used to send the notification emails (the "From" address).
MAIL_USERNAME=your.address@gmail.com

# Gmail "app password" — 16 chars, no spaces. NOT your normal Google password.
# Create at: https://myaccount.google.com/apppasswords  (requires 2-step verification)
MAIL_PASSWORD=xxxxxxxxxxxxxxxx

# Where the digest emails are delivered. Can be the same as MAIL_USERNAME.
NOTIFY_TO=your.address@gmail.com

# Optional. When true (default), only Hungarian-friendly listings are kept —
# titles containing Greek or Polish-only letters are filtered out. Set to false
# to receive matches in any language. Can also be toggled from the Settings page.
# FILTER_HUNGARIAN_ONLY=true
